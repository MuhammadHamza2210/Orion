# Ollama host (REST API base URL)
OLLAMA_HOST=http://localhost:11434

# Ollama model used for AI analysis
OLLAMA_MODEL=llama3.2:1b

# How often (seconds) to refresh stock data from yfinance
REFRESH_INTERVAL=5

# DEMO_MODE=true skips yfinance entirely and uses the built-in price simulator.
# Set this to true if you have no internet or Yahoo Finance is rate-limiting you.
# Leave false to use real data (and auto-simulate only the tickers that fail).
DEMO_MODE=false

# How often (seconds) to broadcast cached data over the WebSocket
BROADCAST_INTERVAL=5

# Allowed CORS origin for the frontend dev server
FRONTEND_ORIGIN=http://localhost:5173
